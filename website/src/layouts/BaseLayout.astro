---
import '../styles/global.css';
import JsonLd from '../components/JsonLd.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import { personJsonLd } from '../lib/jsonld';
import { siteOgUrl } from '../lib/og-url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  publishedTime?: string; // ISO date, only used when ogType === 'article'
  tags?: string[]; // article:tag, only used when ogType === 'article'
}

const {
  title,
  description = 'Juraci Paixão Kröhling — CEO of OllyGarden, OpenTelemetry Governance, speaker on observability and distributed tracing.',
  ogImage = siteOgUrl(Astro.site!),
  ogType = 'website',
  publishedTime,
  tags = [],
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteTitle = title === 'Juraci Paixão Kröhling' ? title : `${title} · Juraci Paixão Kröhling`;
const person = personJsonLd(Astro.site!);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Juraci Paixão Kröhling" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta property="og:site_name" content="Juraci Paixão Kröhling" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={siteTitle} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && <meta property="article:author" content="Juraci Paixão Kröhling" />}
    {ogType === 'article' &&
      tags.map((t) => <meta property="article:tag" content={t} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <JsonLd data={person} />
  </head>
  <body>
    <a class="skip-to-content" href="#main">Skip to content</a>
    <SiteNav />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
