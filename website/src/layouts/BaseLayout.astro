---
import '../styles/global.css';
import JsonLd from '../components/JsonLd.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import { personJsonLd } from '../lib/jsonld';
import { siteOgUrl } from '../lib/og-url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Juraci Paixão Kröhling — speaker, engineer, OpenTelemetry Governance, co-founder of OllyGarden.',
  ogImage = siteOgUrl(Astro.site!),
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteTitle = title === 'Juraci Paixão Kröhling' ? title : `${title} · Juraci Paixão Kröhling`;
const person = personJsonLd(Astro.site!);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Juraci Paixão Kröhling" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <JsonLd data={person} />
  </head>
  <body>
    <a class="skip-to-content" href="#main">Skip to content</a>
    <SiteNav />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
