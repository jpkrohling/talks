---
const year = new Date().getFullYear();
---
<footer>
  <div class="container inner">
    <p>© {year} Juraci Paixão Kröhling</p>
    <ul>
      <li><a href="https://linktr.ee/jpkroehling" rel="me">linktr.ee</a></li>
      <li><a href="https://github.com/jpkrohling" rel="me">GitHub</a></li>
      <li><a href="https://www.linkedin.com/in/jpkroehling" rel="me">LinkedIn</a></li>
      <li><a href="https://speakerdeck.com/jpkroehling" rel="me">SpeakerDeck</a></li>
    </ul>
  </div>
</footer>
<style>
  footer { border-top: 1px solid var(--cream-200); background: var(--cream-50); margin-top: var(--space-24); }
  .inner { display: flex; justify-content: space-between; align-items: center; padding-block: var(--space-6); flex-wrap: wrap; gap: var(--space-4); }
  p { margin: 0; color: var(--ink-600); font-size: 0.875rem; }
  ul { display: flex; gap: var(--space-4); list-style: none; margin: 0; padding: 0; font-size: 0.875rem; }
  ul a { color: var(--ink-600); }
</style>
