# build output
dist/
# generated types
.astro/
# pre-build step copies slides here from ../YYYY/*/slides.pdf
public/talks/
# pre-build step copies headshots here from ../headshots/
public/press-assets/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# generated OG images: per-talk PNGs are generated at build and ignored;
# the fixed page OGs (default/home/cv/talks/projects/press/badges) are
# produced by generate-default-og.ts and tracked so CI/dev builds don't
# need network access to Fontsource to render them.
public/og/*.png
!public/og/default.png
!public/og/home.png
!public/og/cv.png
!public/og/talks.png
!public/og/projects.png
!public/og/press.png
!public/og/badges.png
public/og/.cache.json
